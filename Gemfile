source 'https://rubygems.org'
ruby ">= 3.3.0"

gem 'rails', '~> 8.0.0'

gem 'sqlite3'

# Turso (libSQL) database support
gem 'libsql_activerecord'

# use rack-cors to handle cross-origin requests
gem 'rack-cors'

gem 'sprockets-rails'

# Let's encrypt for free SSL certs
gem 'platform-api'
gem 'letsencrypt-rails-heroku', group: 'production'

# Use SCSS for stylesheets
gem 'sass-rails'
# Use CoffeeScript for .coffee assets and views
gem 'coffee-rails'

# Use angular-rails-templates to permit easy organization of angular frontend files
gem 'angular-rails-templates'
# Use responders for json respond_to
gem 'responders'

# jQuery
gem 'jquery-rails'
gem 'jquery-ui-rails'
# Turbolinks makes following links in your web application faster
gem 'turbolinks'
# Build JSON APIs with ease
gem 'jbuilder', '~> 2.0'

# use Curb to make calls to API
gem 'curb', '~> 0.9.7'

# use Mechanize to get TV Show info
gem 'mechanize'
gem 'connection_pool', '>= 2.5', '< 3.0'

# Puma web server
gem 'puma', '~> 6.0'


group :development, :test do
  gem 'byebug'
end

group :development do
  gem 'web-console', '~> 4.0'
  gem 'spring'
end

